// --- PINES MOTORES (Configuración Yahboom) ---
const int M1INA = 2; 
const int M1INB = 4;
const int M1PWM = 9; 
const int M1ENA = 6; 

const int M2INA = 7; 
const int M2INB = 8;
const int M2PWM = 10; 
const int M2ENA = 12; 

// --- PIN VENTOSA ---
const int PIN_VENTOSA = 5;

void setup() {
  Serial.begin(115200); 
  // Reducimos el timeout para que el Arduino no se quede "congelado" esperando datos
  Serial.setTimeout(10); 
  
  pinMode(M1INA, OUTPUT); pinMode(M1INB, OUTPUT); pinMode(M1PWM, OUTPUT); pinMode(M1ENA, OUTPUT); 
  pinMode(M2INA, OUTPUT); pinMode(M2INB, OUTPUT); pinMode(M2PWM, OUTPUT); pinMode(M2ENA, OUTPUT); 
  pinMode(PIN_VENTOSA, OUTPUT);

  // Activamos los ENA
  digitalWrite(M1ENA, HIGH); 
  digitalWrite(M2ENA, HIGH); 
  
  digitalWrite(PIN_VENTOSA, LOW);
}

void loop() {
  if (Serial.available() > 0) {
    char comando = Serial.read();

    // --- CONTROL VENTOSA --- 
    if (comando == 'V') digitalWrite(PIN_VENTOSA, HIGH); // ON
    else if (comando == 'v') digitalWrite(PIN_VENTOSA, LOW); // OFF

    // --- PARADA DE EMERGENCIA ---
    else if (comando == 'S') { 
      controlMotorIzquierdo(0);
      controlMotorDerecho(0);
    }

    // --- NUEVO CONTROL DIFERENCIAL (EJ: "M 40 20\n") ---
    else if (comando == 'M') {
      // Lee los dos números que vienen después de la 'M'
      int vel_izq = Serial.parseInt(); // Velocidad para Motor 2 (Izquierdo)
      int vel_der = Serial.parseInt(); // Velocidad para Motor 1 (Derecho)
      
      controlMotorIzquierdo(vel_izq);
      controlMotorDerecho(vel_der);
    }
  }
}

// ==========================================
// FUNCIONES AUXILIARES PARA MOTORES
// Permiten ir hacia adelante (vel > 0) y hacia atrás (vel < 0)
// ==========================================

void controlMotorDerecho(int velocidad) {
  if (velocidad > 0) { // Adelante
    digitalWrite(M1INA, HIGH); 
    digitalWrite(M1INB, LOW);
    analogWrite(M1PWM, velocidad);
  } 
  else if (velocidad < 0) { // Atrás (invertimos polaridad)
    digitalWrite(M1INA, LOW); 
    digitalWrite(M1INB, HIGH);
    // Usamos abs() porque analogWrite solo acepta valores positivos (0-255)
    analogWrite(M1PWM, abs(velocidad)); 
  } 
  else { // Parar (0)
    digitalWrite(M1INA, LOW); 
    digitalWrite(M1INB, LOW);
    analogWrite(M1PWM, 0);
  }
}

void controlMotorIzquierdo(int velocidad) {
  if (velocidad > 0) { // Adelante
    digitalWrite(M2INA, HIGH); 
    digitalWrite(M2INB, LOW);
    analogWrite(M2PWM, velocidad);
  } 
  else if (velocidad < 0) { // Atrás (invertimos polaridad)
    digitalWrite(M2INA, LOW); 
    digitalWrite(M2INB, HIGH);
    analogWrite(M2PWM, abs(velocidad)); 
  } 
  else { // Parar (0)
    digitalWrite(M2INA, LOW); 
    digitalWrite(M2INB, LOW);
    analogWrite(M2PWM, 0);
  }
}
